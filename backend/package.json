{
  "name": "nfl-sentiment-analyzer-backend",
  "version": "1.0.0",
  "description": "Backend service for NFL sentiment analysis",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
